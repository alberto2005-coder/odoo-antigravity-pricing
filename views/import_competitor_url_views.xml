<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard View -->
    <record id="view_import_competitor_url_wizard_form" model="ir.ui.view">
        <field name="name">import.competitor.url.wizard.form</field>
        <field name="model">import.competitor.url.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Competitor URLs">
                <sheet>
                    <group>
                        <field name="filename" invisible="1"/>
                        <field name="csv_file" filename="filename"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <h5>CSV Format Instructions:</h5>
                        <p>The CSV file should contain the following headers:</p>
                        <ul>
                            <li><strong>sku</strong> (or <em>default_code</em>): The product reference/SKU (e.g. SKU-001)</li>
                            <li><strong>platform</strong>: <code>amazon</code>, <code>google</code>, or <code>custom</code></li>
                            <li><strong>url</strong>: The full URL to scrape</li>
                        </ul>
                        <p><em>Example:</em></p>
                        <pre>sku,platform,url
SKU-001,amazon,https://www.amazon.es/dp/...
SKU-002,google,https://shopping.google.com/...
SKU-003,custom,https://competitor.com/product/abc</pre>
                    </div>
                </sheet>
                <footer>
                    <button string="Import" class="btn-primary" type="object" name="action_import" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for Wizard -->
    <record id="action_import_competitor_url_wizard" model="ir.actions.act_window">
        <field name="name">Import Competitor URLs</field>
        <field name="res_model">import.competitor.url.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Item for Wizard -->
    <menuitem id="menu_import_competitor_url" 
              name="Import Competitor URLs" 
              parent="sale.product_menu_catalog" 
              action="action_import_competitor_url_wizard" 
              sequence="105"/>

    <!-- List View for Competitor URLs (to allow export) -->
    <record id="view_dynamic_competitor_url_tree" model="ir.ui.view">
        <field name="name">dynamic.competitor.url.tree</field>
        <field name="model">dynamic.competitor.url</field>
        <field name="arch" type="xml">
            <tree string="Competitor URLs" editable="bottom">
                <field name="product_id"/>
                <field name="platform"/>
                <field name="url" widget="url"/>
                <field name="last_scraped_price"/>
                <field name="last_scraped_date"/>
            </tree>
        </field>
    </record>

    <!-- Action for Competitor URLs List -->
    <record id="action_dynamic_competitor_url" model="ir.actions.act_window">
        <field name="name">Competitor URLs Catalog</field>
        <field name="res_model">dynamic.competitor.url</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Item for Competitor URLs List -->
    <menuitem id="menu_dynamic_competitor_url" 
              name="Competitor URLs" 
              parent="sale.product_menu_catalog" 
              action="action_dynamic_competitor_url" 
              sequence="102"/>
</odoo>
