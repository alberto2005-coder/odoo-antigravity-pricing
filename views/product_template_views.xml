<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_dynamic_pricing" model="ir.ui.view">
        <field name="name">product.template.form.dynamic.pricing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_dynamic_price_logs" type="object" 
                        class="oe_stat_button" icon="fa-line-chart"
                        invisible="not dynamic_pricing_active">
                    <field name="dynamic_price_log_count" widget="statinfo" string="Price Fluctuation"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Dynamic Competitor Pricing" name="dynamic_competitor_pricing">
                    <group>
                        <group string="Settings">
                            <field name="dynamic_pricing_active" widget="boolean_toggle"/>
                            <field name="min_margin" invisible="not dynamic_pricing_active"/>
                            <field name="competitor_alert_threshold" invisible="not dynamic_pricing_active"/>
                        </group>
                        <group string="Adjustment Rules" invisible="not dynamic_pricing_active">
                            <field name="competitor_rule"/>
                            <field name="rule_value"/>
                        </group>
                    </group>
                    
                    <group string="Competitor URLs" invisible="not dynamic_pricing_active">
                        <field name="competitor_url_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="platform"/>
                                <field name="url"/>
                                <field name="last_scraped_price"/>
                                <field name="last_scraped_date"/>
                            </tree>
                        </field>
                    </group>

                    <group string="Sales Performance Impact Analysis" invisible="not dynamic_pricing_active">
                        <group string="With Dynamic Pricing (Active Period)">
                            <field name="dynamic_pricing_sales_qty"/>
                            <field name="dynamic_pricing_sales_revenue"/>
                        </group>
                        <group string="Without Dynamic Pricing (Previous Period)">
                            <field name="dynamic_pricing_sales_qty_before"/>
                            <field name="dynamic_pricing_sales_rev_before"/>
                        </group>
                        <group string="Strategy ROI Metrics" colspan="2">
                            <field name="sales_improvement_qty_pct" widget="float" decoration-success="sales_improvement_qty_pct &gt; 0" decoration-danger="sales_improvement_qty_pct &lt; 0"/>
                            <field name="sales_improvement_rev_pct" widget="float" decoration-success="sales_improvement_rev_pct &gt; 0" decoration-danger="sales_improvement_rev_pct &lt; 0"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
