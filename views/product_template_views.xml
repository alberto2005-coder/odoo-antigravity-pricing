<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_dynamic_pricing" model="ir.ui.view">
        <field name="name">product.template.form.dynamic.pricing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_dynamic_price_logs" type="object" 
                        class="oe_stat_button" icon="fa-line-chart"
                        invisible="not dynamic_pricing_active">
                    <field name="dynamic_price_log_count" widget="statinfo" string="Price Fluctuation"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Dynamic Competitor Pricing" name="dynamic_competitor_pricing">
                    <group>
                        <group>
                            <field name="dynamic_pricing_active" widget="boolean_toggle"/>
                            <field name="min_margin" invisible="not dynamic_pricing_active"/>
                        </group>
                        <group>
                            <field name="competitor_rule" invisible="not dynamic_pricing_active"/>
                            <field name="rule_value" invisible="not dynamic_pricing_active"/>
                        </group>
                    </group>
                    <group string="Competitor URLs" invisible="not dynamic_pricing_active">
                        <field name="competitor_url_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="platform"/>
                                <field name="url"/>
                                <field name="last_scraped_price"/>
                                <field name="last_scraped_date"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
